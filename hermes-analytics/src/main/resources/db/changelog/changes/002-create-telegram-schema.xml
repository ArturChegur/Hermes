<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-telegram-user" author="ArturChegur">
        <createTable tableName="telegram_user">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_telegram_user" nullable="false"/>
            </column>
            <column name="telegram_user_id" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_telegram_user_telegram_user_id"/>
            </column>
            <column name="username" type="VARCHAR(255)"/>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="last_name" type="VARCHAR(255)"/>
            <column name="language_code" type="VARCHAR(32)"/>
        </createTable>

        <createIndex tableName="telegram_user" indexName="idx_telegram_user_username">
            <column name="username"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-telegram-chat" author="ArturChegur">
        <createTable tableName="telegram_chat">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_telegram_chat" nullable="false"/>
            </column>
            <column name="telegram_chat_id" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_telegram_chat_telegram_chat_id"/>
            </column>
            <column name="chat_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="chat_title" type="VARCHAR(255)"/>
            <column name="chat_username" type="VARCHAR(255)"/>
        </createTable>

        <createIndex tableName="telegram_chat" indexName="idx_telegram_chat_type">
            <column name="chat_type"/>
        </createIndex>

        <createIndex tableName="telegram_chat" indexName="idx_telegram_chat_username">
            <column name="chat_username"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-telegram-message" author="ArturChegur">
        <createTable tableName="telegram_message">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_telegram_message" nullable="false"/>
            </column>
            <column name="telegram_update_id" type="BIGINT">
                <constraints unique="true" uniqueConstraintName="uk_telegram_message_update_id"/>
            </column>
            <column name="telegram_message_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="message_date" type="TIMESTAMP"/>
            <column name="text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="user_ref" type="BIGINT"/>
            <column name="chat_ref" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="telegram_message"
                baseColumnNames="user_ref"
                referencedTableName="telegram_user"
                referencedColumnNames="id"
                constraintName="fk_telegram_message_user"/>

        <addForeignKeyConstraint
                baseTableName="telegram_message"
                baseColumnNames="chat_ref"
                referencedTableName="telegram_chat"
                referencedColumnNames="id"
                constraintName="fk_telegram_message_chat"/>

        <addUniqueConstraint
                tableName="telegram_message"
                columnNames="chat_ref, telegram_message_id"
                constraintName="uk_telegram_message_chat_message"/>

        <createIndex tableName="telegram_message" indexName="idx_telegram_message_chat_ref">
            <column name="chat_ref"/>
        </createIndex>

        <createIndex tableName="telegram_message" indexName="idx_telegram_message_user_ref">
            <column name="user_ref"/>
        </createIndex>

        <createIndex tableName="telegram_message" indexName="idx_telegram_message_date">
            <column name="message_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>